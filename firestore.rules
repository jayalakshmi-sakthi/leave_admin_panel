rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────
    // 🛠 HELPER FUNCTIONS
    // ─────────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasUserDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function myUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    /// Super Admin check (Case-insensitive + Email bypass)
    function isSuperAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email.lower() == 'leave752@gmail.com' ||
              (hasUserDoc() && (myUserDoc().role in ['super_admin', 'SUPER_ADMIN', 'Super Admin'])));
    }

    /// Admin check
    function isAdmin() {
      return isSuperAdmin() || 
             (isAuthenticated() && hasUserDoc() &&
              (myUserDoc().role in ['admin', 'ADMIN', 'Admin']));
    }

    /// Admin of Department check (includes Super Admins & 'All' department admins)
    function isAdminOfDept(dept) {
      return isSuperAdmin() || 
             (isAuthenticated() && hasUserDoc() && 
              (myUserDoc().role in ['admin', 'ADMIN', 'Admin']) &&
              (myUserDoc().department == dept || myUserDoc().department == 'All'));
    }

    // ─────────────────────────────────────────────────────────────
    // 👤 USERS COLLECTION
    // Each admin can read users from their own department only.
    // Staff can read/write their own document.
    // ─────────────────────────────────────────────────────────────
    match /users/{userId} {
      // 🔓 PUBLIC LOGIN LOOKUP
      allow list: if request.auth == null && request.query.limit == 1;

      // Staff: Read/Write own document
      allow read, write: if isAuthenticated() && request.auth.uid == userId;

      // Admin/Super Admin: Management access
      // Allow read/create/update if Admin of the target department
      allow read: if isAdminOfDept(resource.data.department);
      allow create, update: if isAdminOfDept(request.resource.data.department);

      // Allow delete only for Super Admin
      allow delete: if isSuperAdmin();

      // Comp-Off Grants (legacy path)
      match /compOffGrants/{grantId} {
        allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
        allow write: if isAdmin();
      }
    }

    // ─────────────────────────────────────────────────────────────
    // 📝 LEAVE REQUESTS — Department-isolated
    // Path: leaveRequests/{dept}/records/{id}
    // ─────────────────────────────────────────────────────────────
    match /leaveRequests/{dept}/records/{requestId} {
      // Staff can CREATE in their own department
      allow create: if isAuthenticated() &&
                       hasUserDoc() &&
                       myUserDoc().department == dept;

      // Read: own request OR admin of this dept
      allow read: if isAuthenticated() &&
                     (resource.data.userId == request.auth.uid ||
                      isAdminOfDept(dept));

      // Update/Delete: own request (for edit before approval) OR admin of this dept
      allow update: if isAuthenticated() &&
                       (resource.data.userId == request.auth.uid ||
                        isAdminOfDept(dept));

      allow delete: if isAdminOfDept(dept);
    }

    // ─────────────────────────────────────────────────────────────
    // 🔀 COMP OFF REQUESTS — Department-isolated
    // Path: compOffRequests/{dept}/records/{id}
    // ─────────────────────────────────────────────────────────────
    match /compOffRequests/{dept}/records/{requestId} {
      allow create: if isAuthenticated() &&
                       hasUserDoc() &&
                       myUserDoc().department == dept;

      allow read: if isAuthenticated() &&
                     (resource.data.userId == request.auth.uid ||
                      isAdminOfDept(dept));

      allow update: if isAuthenticated() &&
                       (resource.data.userId == request.auth.uid ||
                        isAdminOfDept(dept));

      allow delete: if isAdminOfDept(dept);
    }

    // ─────────────────────────────────────────────────────────────
    // 🏢 DEPARTMENTS — All dept-specific settings live here
    // Path: departments/{dept}/...
    // Admins can write; ALL authenticated users can READ
    // (staff need leave types & academic year for the apply form)
    // ─────────────────────────────────────────────────────────────
    match /departments/{dept} {
      // ✅ All authenticated users can read the dept document
      // (leaveTypes, currentAcademicYear, etc. are stored here)
      allow read: if isAuthenticated();
      allow write: if isAdminOfDept(dept);

      // Academic Years scoped to dept — staff need to read!
      match /academicYears/{yearId} {
        allow read: if isAuthenticated();
        allow write: if isAdminOfDept(dept);
      }

      // Settings (leave_types, academic_year, etc.) — staff need to read!
      match /settings/{docId} {
        allow read: if isAuthenticated();
        allow write: if isAdminOfDept(dept);
      }

      // Comp Off Grants scoped to dept
      match /compOffGrants/{grantId} {
        allow read: if isAdminOfDept(dept) ||
                       (isAuthenticated() && hasUserDoc() && resource.data.userId == request.auth.uid);
        allow write: if isAdminOfDept(dept);
        allow create: if isAdminOfDept(dept);
      }
    }

    // ─────────────────────────────────────────────────────────────
    // 📅 ACADEMIC YEARS (legacy global — kept for backward compat)
    // New data should go to departments/{dept}/academicYears
    // ─────────────────────────────────────────────────────────────
    match /academicYears/{yearId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();

      match /deptCounters/{dept} {
        allow read, write: if isAuthenticated();
      }
    }

    // ─────────────────────────────────────────────────────────────
    // ⚙️ SETTINGS (legacy global — read-only for backward compat)
    // ─────────────────────────────────────────────────────────────
    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin(); // Only super admin can change global settings
    }

    // ─────────────────────────────────────────────────────────────
    // 🔔 NOTIFICATIONS — per-user (already isolated by toUserId)
    // ─────────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() &&
                     (resource.data.toUserId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() &&
                       (resource.data.toUserId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() &&
                       (resource.data.toUserId == request.auth.uid || isAdmin());
    }

    // ─────────────────────────────────────────────────────────────
    // 🔢 COUNTERS (for ID generation)
    // ─────────────────────────────────────────────────────────────
    match /counters/{counterId} {
      allow read, update, create: if isAuthenticated();
    }

    // ─────────────────────────────────────────────────────────────
    // 📤 FCM QUEUE (Cloud Functions only)
    // ─────────────────────────────────────────────────────────────
    match /fcm_queue/{docId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // 🌐 COLLECTION GROUP: records (read own requests across depts)
    // Used by staff mobile app to see their own requests
    // ─────────────────────────────────────────────────────────────
    match /{path=**}/records/{requestId} {
      allow read: if isAuthenticated() &&
                     (resource.data.userId == request.auth.uid ||
                      (hasUserDoc() && resource.data.department == myUserDoc().department) ||
                      isSuperAdmin());
      allow update: if isAuthenticated() &&
                       (resource.data.userId == request.auth.uid ||
                        (hasUserDoc() && resource.data.department == myUserDoc().department &&
                         myUserDoc().role in ['admin', 'super_admin']) ||
                        isSuperAdmin());
    }

    // ─────────────────────────────────────────────────────────────
    // 🌐 COLLECTION GROUP: compOffGrants (for staff to see earned comp-offs)
    // ─────────────────────────────────────────────────────────────
    match /{path=**}/compOffGrants/{grantId} {
      allow read: if isAuthenticated() &&
                     (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
