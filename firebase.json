{
    "flutter": {
        "platforms": {
            "dart": {
                "lib/firebase_options.dart": {
                    "projectId": "leave-management-app-f07b8",
                    "configurations": {
                        "web": "1:476708106662:web:2f4f6cc251fa2db9e69f67"
                    }
                }
            }
        }
    },
    "hosting": {
        "target": "admin-app",
        "public": "build/web",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "rewrites": [
            {
                "source": "**",
                "destination": "/index.html"
